---
import type { Clipping } from '../lib/coverage';
import { formatReach, formatDate } from '../lib/coverage';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  clippings: Clipping[];
}

const { clippings } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const screenshotsDir = path.resolve('public/coverage/screenshots');

// Resolve which screenshot file (if any) exists for each clipping.
function resolveScreenshot(id: string): string | null {
  for (const ext of ['.jpg', '.jpeg', '.png', '.webp']) {
    if (fs.existsSync(path.join(screenshotsDir, id + ext))) {
      return `${base}/coverage/screenshots/${id}${ext}`;
    }
  }
  return null;
}

const cards = clippings.map((c) => ({ ...c, screenshot: resolveScreenshot(c.id) }));
---
{cards.length === 0 ? (
  <p class="text-sm italic text-zinc-400">No highlights selected yet.</p>
) : (
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {cards.map((c) => (
      <a
        href={c.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col overflow-hidden rounded-lg border border-zinc-200 bg-white transition-all hover:border-zinc-400 hover:shadow-md"
      >
        <div class="relative aspect-[16/10] w-full overflow-hidden bg-zinc-100">
          {c.screenshot ? (
            <img
              src={c.screenshot}
              alt={`${c.outlet} — ${c.campaign_display ?? ''}`}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              loading="lazy"
            />
          ) : (
            <div class="flex h-full w-full flex-col items-center justify-center gap-2 px-4 text-center">
              <span class="text-base font-semibold tracking-tight text-zinc-700">{c.outlet}</span>
              {c.campaign_display && (
                <span class="text-xs text-zinc-500">{c.campaign_display}</span>
              )}
            </div>
          )}
        </div>
        <div class="flex items-center justify-between gap-3 border-t border-zinc-100 px-4 py-3 text-xs">
          <div class="flex flex-col gap-0.5">
            <span class="font-medium text-zinc-800">{c.outlet}</span>
            <span class="text-zinc-400">{formatDate(c.date)} · {c.region ?? '—'}</span>
          </div>
          {c.reach != null && (
            <span class="rounded-full bg-zinc-100 px-2 py-0.5 font-medium text-zinc-700">
              {formatReach(c.reach)}
            </span>
          )}
        </div>
      </a>
    ))}
  </div>
)}
