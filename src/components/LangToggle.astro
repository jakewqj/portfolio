---
---
<div class="no-print inline-flex items-center rounded-full border border-zinc-300 bg-white p-0.5 text-sm">
  <button
    type="button"
    data-lang-btn="zh"
    class="rounded-full px-3 py-1 font-medium text-zinc-500 transition-colors hover:text-zinc-900"
    aria-label="切换到中文"
  >中文</button>
  <button
    type="button"
    data-lang-btn="en"
    class="rounded-full px-3 py-1 font-medium text-zinc-500 transition-colors hover:text-zinc-900"
    aria-label="Switch to English"
  >EN</button>
</div>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const setActive = (lang) => {
      root.dataset.lang = lang;
      try { localStorage.setItem('lang', lang); } catch (_) {}
      document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
        const active = btn.getAttribute('data-lang-btn') === lang;
        btn.classList.toggle('bg-zinc-900', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('text-zinc-500', !active);
      });
    };
    document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
      btn.addEventListener('click', () => setActive(btn.getAttribute('data-lang-btn')));
    });
    // Reflect current state once components are wired up
    setActive(root.dataset.lang || 'zh');
  })();
</script>
