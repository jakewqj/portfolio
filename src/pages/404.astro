---
import Base from '../layouts/Base.astro';
---
<Base title="404 · Jake Wu">
  <main class="mx-auto flex min-h-screen max-w-md items-center px-6 text-center">
    <div class="w-full">
      <p class="text-xs uppercase tracking-widest text-zinc-400">404</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight text-zinc-900">
        <span data-lang-section="zh">页面未找到</span>
        <span data-lang-section="en">Page not found</span>
      </h1>
      <p class="mt-3 text-sm text-zinc-500">
        <span data-lang-section="zh">请确认链接是否正确。</span>
        <span data-lang-section="en">Please double-check the link.</span>
      </p>
    </div>
  </main>
</Base>
